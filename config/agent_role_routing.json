    },
    "delivery-review": {
      "required_lane": "review",
      "allowed_roles": [
        "primary-chat",
        "formal-reviewer"
      ],
      "preferred_model_family": "strongest_review",
      "required_effort_key": "highest_review_tier",
      "failure_outcome": "review-required",
