        "technical_review": [
          "gpt-5.6-terra"
        ],
        "governance_review": [
          "gpt-5.4"
        ],
        "monitoring": [
          "gpt-5.4-mini"
        ]
      },
      "notes": [
        "Codex routing is currently enforced through declared preflight evidence plus explicit waiver handling.",
        "Routine code and implementation-side execution should default to gpt-5.6-luna.",
        "Architecture decision/final/security review uses gpt-5.6-sol; technical delivery lanes use gpt-5.6-terra; architecture adherence and adjudication use gpt-5.4."
      ]
    },
    "claude-code": {
      "display_name": "Claude Code",
      "allowed_proof_modes": [
        "artifact",
        "declared",
        "waiver"
      ],
      "requires_effort": true,
      "preferred_models": {
        "routine_executor": [
          "sonnet"
        ],
        "strongest_review": [
          "opus"
        ],
        "technical_review": [
          "sonnet"
        ],
        "governance_review": [
          "sonnet"
        ],
        "monitoring": [
          "haiku",
          "sonnet"
        ]
      },
      "notes": [
        "Claude Code can use generated .claude/agents artifacts as first-class routing proof.",
        "Routine implementation should default to Sonnet-class subagents.",
        "Formal review should default to Opus-class review agents."
      ]
    },
    "cline-ide": {
      "display_name": "Cline IDE",
      "allowed_proof_modes": [
        "declared",
        "waiver"
      ],
      "requires_effort": false,
      "preferred_models": {
        "routine_executor": [
          "sonnet",
          "sonnet-or-best-available-routine-coding-model"
        ],
        "strongest_review": [
          "opus",
          "opus-or-strongest-available-review-model"
        ],
        "technical_review": [
          "sonnet",
          "sonnet-or-best-available-routine-coding-model"
        ],
        "governance_review": [
          "sonnet",
          "sonnet-or-best-available-routine-coding-model"
        ],
        "monitoring": [
          "haiku",
          "haiku-or-best-available-cheap-monitoring-model"
        ]
      },
      "notes": [
        "Cline support is declarative/hook-level only in this first slice.",
        "When the provider/model cannot be proven exactly, keep the declared routing visible and require waiver handling for real deviations."
      ]
    }
