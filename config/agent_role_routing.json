  "surfaces": {
    "implementation": {
      "required_lane": "executor",
      "allowed_roles": [
        "routine-executor"
      ],
      "preferred_model_family": "routine_executor",
      "required_effort_key": "medium",
      "failure_outcome": "delegate-required",
      "waiver_allowed": true,
      "allowed_exception_reasons": [
        "bootstrap-guard-implementation",
        "reconciliation",
        "merge-conflict",
        "minimal-integration-glue"
      ],
      "state_policy": "sticky-per-chat-or-todo-compact-state",
      "goal_policy": "required-when-supported",
      "notes": [
        "Code writing and direct file-edit execution belong to the routine executor lane.",
        "Primary-chat implementation is allowed only through an explicit approved exception."
      ]
    },
    "implementation-validation": {
      "required_lane": "executor",
      "allowed_roles": [
        "routine-executor"
      ],
      "preferred_model_family": "routine_executor",
      "required_effort_key": "medium",
      "failure_outcome": "delegate-required",
      "waiver_allowed": true,
      "allowed_exception_reasons": [
        "bootstrap-guard-implementation",
        "reconciliation",
        "merge-conflict",
        "minimal-integration-glue"
      ],
      "state_policy": "sticky-per-chat-or-todo-compact-state",
      "goal_policy": "required-when-supported",
      "notes": [
        "Implementation-side test/build/command execution stays in the same lane as the owned implementation.",
        "Do not pull implementation validation back into the primary chat by default."
      ]
    },
    "monitoring": {
      "required_lane": "monitor",
      "allowed_roles": [
