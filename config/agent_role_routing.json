      "required_effort_key": "low_or_medium",
      "failure_outcome": "delegate-required",
      "waiver_allowed": true,
      "allowed_exception_reasons": [],
      "state_policy": "ephemeral-bounded-status-pass",
      "goal_policy": "not-needed",
      "notes": [
        "Monitoring is deterministic first.",
        "If an LLM is needed, keep the pass bounded and ephemeral instead of letting the primary chat watch verbose logs."
      ]
    },
    "formal-review": {
      "required_lane": "review",
      "allowed_roles": [
        "primary-chat",
        "formal-reviewer"
      ],
      "preferred_model_family": "strongest_review",
      "required_effort_key": "highest_review_tier",
      "failure_outcome": "review-required",
      "waiver_allowed": true,
      "allowed_exception_reasons": [],
      "state_policy": "stateless-no-context-review",
      "goal_policy": "stateless-default",
      "notes": [
        "Formal critique, audit, and no-context review belong to the strongest review lane.",
        "Review surfaces should stay stateless by default."
      ]
    },
    "todo-approval": {
      "required_lane": "review",
      "allowed_roles": [
        "primary-chat",
        "formal-reviewer"
      ],
