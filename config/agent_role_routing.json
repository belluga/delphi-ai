      "failure_outcome": "review-required",
      "waiver_allowed": true,
      "allowed_exception_reasons": [],
      "state_policy": "primary-chat-state-or-stateless-review",
      "goal_policy": "not-needed",
      "notes": [
        "Approval and plan-review surfaces are review-material judgment lanes.",
        "Use the strongest review model/tier that the client exposes."
