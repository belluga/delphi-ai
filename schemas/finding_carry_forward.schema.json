{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paced.internal/schemas/finding_carry_forward.schema.json",
  "title": "PACED Finding Carry-Forward",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_kind",
    "authoritative",
    "edit_policy",
    "todo_path",
    "policy_lines",
    "entries"
  ],
  "properties": {
    "schema_version": {
      "const": "finding-carry-forward-v1"
    },
    "artifact_kind": {
      "const": "finding_carry_forward"
    },
    "authoritative": {
      "const": false
    },
    "edit_policy": {
      "const": "derived_from_todo"
    },
    "todo_path": {
      "type": "string",
      "minLength": 1
    },
    "policy_lines": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "entry": {
      "type": "object",
      "required": [
        "source_kind",
        "finding_id",
        "carry_forward_class",
        "source_disposition",
        "summary",
        "reference"
      ],
      "properties": {
        "source_kind": {
          "enum": [
            "promotion_routing",
            "critique",
            "test_quality_audit",
            "final_review",
            "cutover_integrity_audit"
          ]
        },
        "finding_id": {
          "type": "string",
          "minLength": 1
        },
        "carry_forward_class": {
          "enum": [
            "resolved",
            "challenged",
            "deferred",
            "unresolved"
          ]
        },
        "source_disposition": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "reference": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
